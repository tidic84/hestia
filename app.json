{
  "expo": {
    "name": "Hestia",
    "slug": "hestia",
    "version": "1.0.0",
    "scheme": "hestia",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1c1816"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hestia.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Hestia a besoin de votre caméra pour prendre la photo du jour.",
        "NSLocationWhenInUseUsageDescription": "Hestia utilise votre position pour géolocaliser vos photos sur la carte.",
        "NSPhotoLibraryUsageDescription": "Hestia peut sauvegarder votre récap vidéo dans votre galerie."
      }
    },
    "android": {
      "package": "com.hestia.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1c1816"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD68pakgchFuf6ggQlC0tfUotRj1LMeMNQ"
        }
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Hestia a besoin de votre caméra pour prendre la photo du jour."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hestia utilise votre position pour géolocaliser vos photos sur la carte."
        }
      ],
      [
        "expo-media-library",
        {
          "granularPermissions": ["photo"]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C27D65"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c7305039-3b26-4ecb-8f77-2e8b388e9496"
      }
    },
    "owner": "tidic"
  }
}
